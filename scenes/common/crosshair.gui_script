local player_state = require("ld48.scenes.common.player_state")

local function gui_set_alpha(node, alpha)
    gui.cancel_animation(node, "color.w")
    local color = gui.get_color(node)
    gui.set_color(node, vmath.vector4(color.x, color.y, color.z, alpha))
end

local function gui_anim_alpha(node, alpha, time, delay)
    gui.cancel_animation(node, "color.w")
    gui.animate(node, "color.w", alpha, gui.EASING_OUTQUAD, time, delay or 0)
end

local quiz_questions = {
    { q = "Scenario: You receive an urgent email from your CEO (who is currently traveling) asking you to urgently wire funds to a new vendor to 'close a critical deal'. What is the most secure first step?", options = {"Process the request immediately to avoid losing the deal", "Reply to the email asking for confirmation", "Call the CEO on a known number to verify the request", "Forward the email to the entire finance team"}, ans = 3 },
    { q = "Scenario: A visitor wearing a technician uniform follows you closely through a secure badge-access door without swiping. They are carrying a heavy ladder. What is the correct action?", options = {"Hold the door open to be helpful", "Ignore them and continue to your desk", "Ask them to swipe their badge or escort them to reception", "Take a photo of them and post it on social media"}, ans = 3 },
    { q = "Scenario: You find an unlabelled USB thumb drive in the company parking lot near your car. You want to find out who it belongs to. What should you do?", options = {"Plug it into your workstation to check for a resume", "Plug it into a home computer to be safe", "Turn it over to the IT Security department immediately", "Wipe the drive and use it for your own files"}, ans = 3 },
    { q = "Scenario: While working at a coffee shop, you need to access sensitive company data. The shop offers 'Free-Google-WiFi'. How should you proceed?", options = {"Connect directly and log in to your portals", "Connect but only use HTTPS websites", "Connect only after enabling your company-approved VPN", "Wait until you get home to do any work"}, ans = 3 },
    { q = "Scenario: You receive a phone call from 'Microsoft Support' claiming your computer is sending out viruses and they need remote access to fix it. What is the likely situation?", options = {"A helpful technician is preventing a local outbreak", "It is a remote access trojan (RAT) scam", "Your ISP has reported you to Microsoft", "It is a routine automated security check"}, ans = 2 },
    { q = "Scenario: An app on your phone requests permission to access your 'Location', 'Contacts', and 'Microphone' despite being a simple flashlight app. What should you do?", options = {"Grant all permissions for best performance", "Grant permissions but only while using the app", "Deny permissions and uninstall the suspicious app", "Buy a new phone with better security"}, ans = 3 },
    { q = "Scenario: You're about to post a photo of your new office workstation on LinkedIn to celebrate a promotion. What should you check first?", options = {"Make sure your monitor isn't showing sensitive data", "Check if your password sticky-note is visible", "Ensure no internal badges or keys are in the shot", "All of the above"}, ans = 4 },
    { q = "Scenario: You get a text message (SMS) from 'Your Bank' stating your account is locked and providing a link to 'verify your identity'. The URL is 'bank-secure-auth.net'. What's wrong?", options = {"The bank never uses SMS for alerts", "The domain does not match the official bank website", "You should only verify identity in person", "SMS links are always encrypted and safe"}, ans = 2 },
    { q = "Scenario: Your teammate asks to borrow your laptop for 'just 5 minutes' to check their email because their phone died. They are logged into their own accounts. What is the protocol?", options = {"Let them use it as they are a trusted colleague", "Log out of your sessions and let them use it", "Politely decline; never share your authenticated device", "Watch them the entire time they use it"}, ans = 3 },
    { q = "Scenario: You receive an email with a '.zip' attachment labeled 'Q4_Bonus_Plan'. You weren't expecting this, and the sender's name is spelled slightly wrong. What is the risk?", options = {"The file is too large for your inbox", "It could contain a macro-virus or ransomware", "The misspelled name means it's for someone else", "ZIP files are automatically scanned and safe"}, ans = 2 },
    { q = "Scenario: A suspicious link in an email leads to a site that looks identical to your company's login page. This is an example of:", options = {"Pharming", "Spear Phishing", "Whaling", "Vishing"}, ans = 2 },
    { q = "Scenario: You need to send a file containing customer Personally Identifiable Information (PII) to a partner. How should you send it?", options = {"As a standard email attachment", "Upload to a public file-sharing site", "Through an encrypted, secure file-transfer portal", "Rename the file extension to hide its contents"}, ans = 3 },
    { q = "Scenario: You are leaving your desk for a quick 2-minute coffee break. Your screen is currently showing an internal project plan. What is the best practice?", options = {"Leave it open since you're coming right back", "Turn off the monitor but leave the PC running", "Lock your workstation (Win+L) before leaving", "Ask a neighbor to watch your screen"}, ans = 3 },
    { q = "Scenario: You discover that a co-worker has written their login password on a note under their keyboard. What is the professional response?", options = {"Ignore it; it's their responsibility", "Take a photo of it to prove they are unsafe", "Private inform them and suggest a password manager", "Use it to test if their account has admin rights"}, ans = 3 },
    { q = "Scenario: You receive an email from a known contact, but the tone is strangely formal and they are asking for 'confidential project files'. What should you suspect?", options = {"They have been promoted recently", "Their email account has been compromised", "They are under high stress at work", "It is an automated backup request"}, ans = 2 },
    { q = "Scenario: You notice an unknown device labeled 'Hacker-PC' appearing in your home Wi-Fi network list. What should be your first step?", options = {"Try to hack the device back", "Disconnect your router from the internet", "Change your Wi-Fi password to a stronger one", "Ignore it; it's likely a neighbor's phone"}, ans = 3 },
    { q = "Scenario: An 'Emergency Alert' pop-up on a website says your 'System is Corrupted' and asks you to click a button to 'Scan Now'. What is this?", options = {"A helpful browser security feature", "Scareware designed to trick you into downloading malware", "A legitimate Windows update notification", "A virus that has already infected your machine"}, ans = 2 },
    { q = "Scenario: You are creating a password for a new sensitive account. Which strategy is generally considered the most secure today?", options = {"A short word with many symbols (e.g. P@$$w0rd!)", "A long passphrase of random words (e.g. CorrectHorseBatteryStaple)", "Your pet's name followed by your birth year", "The same password you use for your personal email"}, ans = 2 },
